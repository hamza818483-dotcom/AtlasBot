# ATLAS MCQ BOT - Environment Variables (.env.example)
# Copy this to .env and fill in your actual values
# DO NOT commit .env file to public repository!

# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Owner/Admin Telegram User ID
OWNER_ID=your_owner_id_here

# ============================================
# GOOGLE GEMINI AI CONFIGURATION
# ============================================

# Gemini API keys (comma-separated for rotation)
# Get from: https://aistudio.google.com/apikey
GEMINI_KEYS=key1,key2,key3

# ============================================
# CLOUDFLARE WORKER PROXY
# ============================================

# Cloudflare Worker URL for Telegram API proxy
CF_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# ============================================
# SUPABASE DATABASE CONFIGURATION
# ============================================

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key
SUPABASE_KEY=your_supabase_anon_key_here

# ============================================
# HUGGING FACE SPACE
# ============================================

# Public URL of your HF Space (used for deep links and CORS)
HF_SPACE_URL=https://your-space.hf.space

# ============================================
# QUIZ CONFIGURATION
# ============================================

# Default timer per question (seconds)
QUIZ_TIMER=35

# ============================================
# NOTE:
# - Add these variables in HF Space Settings > Secrets
# - Never commit .env file to public GitHub repo
# - Use .env.example as reference only
# ============================================
