# ATLAS MCQ BOT - Environment Variables (.env.example)
# Copy this to .env and fill in your actual values
# DO NOT commit .env file to public repository!
#
# IMPORTANT: If you run Primary + Backup Render instances (dual-platform
# failover), set ALL of these on BOTH instances identically, otherwise the
# backup instance will silently lose AI fallback/backup features when it
# takes over.

# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
BOT_TOKEN=your_bot_token_here
OWNER_ID=5341425626

# ============================================
# AI PROVIDERS (v4.2 -- Groq is PRIMARY, Gemini is fallback)
# Missing keys are silently skipped -- chain still works with fewer providers.
# ============================================

# Groq (PRIMARY) -- comma-separated keys for rotation
# Get from: https://console.groq.com/keys
GROQ_KEY=key1,key2,key3
# Optional: override models tried in rotation (comma-separated)
GROQ_MODELS=meta-llama/llama-4-scout-17b-16e-instruct,meta-llama/llama-4-maverick-17b-128e-instruct

# Gemini (fallback #1) -- comma-separated keys for rotation
# Get from: https://aistudio.google.com/apikey
GEMINI_KEY=key1,key2,key3

# NVIDIA (fallback #2) -- optional
NVIDIA_KEY=

# OpenRouter family (fallback #3-5) -- optional
OPENROUTER_KEY=
NEMOTRON_KEY=
GEMMA_KEY=

# Cloudflare Workers AI (final fallback) -- optional
CF_ACCOUNT_ID=
CF_AI_TOKEN=

# ============================================
# CLOUDFLARE WORKER PROXY
# ============================================
CF_WORKER_URL=https://atlas-bot-proxy.hamza818483.workers.dev
CF_D1_URL=https://atlas-bot-proxy.hamza818483.workers.dev
CF_D1_TOKEN=your_d1_token_here_must_match_worker_D1_TOKEN_secret
CF_TG_API_URL=https://atlas-bot-proxy-pages.pages.dev

# ============================================
# RENDER PRIMARY / BACKUP FAILOVER (v4.1+)
# Set RUNNING_ON=Render on BOTH Render instances.
# RENDER_URL = this instance's own public URL.
# RENDER_URL_2 = the OTHER Render instance's URL (used for status display
# and the GitHub Actions watchdog, not required on the instance itself).
# ============================================
RUNNING_ON=Render
RENDER_URL=https://atlasbot-pvp7.onrender.com
RENDER_URL_2=https://atlasbot-3tgq.onrender.com
PUBLIC_BASE_URL=

# ============================================
# SUPABASE DATABASE CONFIGURATION
# ============================================
SUPABASE_URL=https://wbdyjpjbczfunyhhmtry.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndiZHlqcGpiY3pmdW55aGhtdHJ5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA2OTI5ODAsImV4cCI6MjA5NjI2ODk4MH0.0WR1sgVsl_1XWZfSd0Pwoe6Uxp-2GMTksfseMn5aWjg
# Optional secondary Supabase mirror (silent if not set)
SUPABASE_BACKUP_URL=
SUPABASE_BACKUP_KEY=

# ============================================
# QUIZ CONFIGURATION
# ============================================
QUIZ_TIMER=35

# ============================================
# NOTE:
# - On Render: set these in each service's Environment tab (do this for
#   BOTH Primary and Backup instances so failover keeps full functionality)
# - Never commit .env file to public GitHub repo
# - Use .env.example as reference only
# ============================================
